{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-company-lab.local/schemas/work-packet-v1.schema.json",
  "title": "Agent Company Work Packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "lane_id",
    "task_id",
    "requester_agent_id",
    "created_utc",
    "title",
    "objective",
    "packet_type",
    "execution_mode",
    "allowed_actions",
    "blocked_actions",
    "required_service_requests",
    "approval_requirements",
    "context_artifacts",
    "expected_outputs",
    "success_criteria",
    "external_side_effects_allowed",
    "real_money_allowed",
    "public_action_allowed",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "work_packet.v1"
    },
    "packet_id": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9_.:-]*$"
    },
    "lane_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "requester_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "created_utc": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "objective": {
      "type": "string",
      "minLength": 10
    },
    "packet_type": {
      "type": "string",
      "enum": [
        "local_research",
        "browser_read_only",
        "public_action",
        "real_money_action",
        "security_report",
        "model_api_execution",
        "service_worker_request"
      ]
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "local_only",
        "requires_service_approval",
        "approved_service_scope"
      ]
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_service_requests": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approval_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate",
          "decision_owner",
          "approval_status",
          "scope"
        ],
        "properties": {
          "gate": {
            "type": "string",
            "minLength": 1
          },
          "decision_owner": {
            "type": "string",
            "minLength": 1
          },
          "approval_status": {
            "type": "string",
            "enum": [
              "not_required",
              "needs_review",
              "approved",
              "rejected"
            ]
          },
          "scope": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "context_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path_or_url",
          "purpose"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path_or_url": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path",
          "required"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "external_side_effects_allowed": {
      "type": "boolean"
    },
    "real_money_allowed": {
      "type": "boolean"
    },
    "public_action_allowed": {
      "type": "boolean"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "span_kind",
        "runtime",
        "api_calls"
      ],
      "properties": {
        "span_kind": {
          "type": "string"
        },
        "runtime": {
          "type": "string"
        },
        "api_calls": {
          "type": "boolean"
        }
      }
    }
  }
}
