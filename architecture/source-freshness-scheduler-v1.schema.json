{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-company-lab.local/schemas/source-freshness-scheduler-v1.schema.json",
  "title": "Agent Company Source Freshness Scheduler v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "created_local_date",
    "purpose",
    "execution_policy",
    "sources",
    "blocked_execution_classes",
    "expected_outputs",
    "metadata"
  ],
  "properties": {
    "schema_version": { "const": "source_freshness_scheduler.v1" },
    "plan_id": { "type": "string", "minLength": 3 },
    "created_local_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "purpose": { "type": "string", "minLength": 10 },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheduler_is_execution",
        "allowed_now",
        "requires_service_approval",
        "prohibited"
      ],
      "properties": {
        "scheduler_is_execution": { "const": false },
        "allowed_now": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "requires_service_approval": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "prohibited": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "lane_id",
          "source_type",
          "cadence",
          "freshness_state",
          "risk_gate",
          "next_check_local_date",
          "allowed_mode",
          "planned_output",
          "notes"
        ],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "lane_id": { "type": "string", "minLength": 1 },
          "source_type": { "type": "string", "minLength": 1 },
          "cadence": { "type": "string", "minLength": 1 },
          "freshness_state": {
            "type": "string",
            "enum": ["fresh", "due", "stale", "blocked_until_approval", "manual_only"]
          },
          "risk_gate": { "type": "string", "minLength": 1 },
          "next_check_local_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "allowed_mode": {
            "type": "string",
            "enum": ["local_file_read", "read_only_github_metadata", "local_planning_only", "service_request_only"]
          },
          "planned_output": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" }
        }
      }
    },
    "blocked_execution_classes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path"],
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["api_calls", "browser_actions", "external_side_effects"],
      "properties": {
        "api_calls": { "type": "boolean" },
        "browser_actions": { "type": "boolean" },
        "external_side_effects": { "type": "boolean" }
      }
    }
  }
}
