{
  "$id": "https://agent-company-lab.local/schemas/durable-runtime-service-worker-reducer-fixture-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Company Durable Runtime Service Worker Reducer Fixture v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "agent_company.durable_runtime_service_worker_reducer_fixture.v1"
    },
    "generated_utc": {
      "type": "string"
    },
    "task_id": {
      "const": "task-durable-runtime-service-worker-reducer-fixture-v1-20260617"
    },
    "lane_id": {
      "const": "platform_engineering"
    },
    "owner_agent_id": {
      "const": "recovered-profitable-edge-infra"
    },
    "source_matrix_path": {
      "type": "string",
      "minLength": 10
    },
    "source_service_worker_queue_path": {
      "type": "string",
      "minLength": 10
    },
    "source_reducer_result_path": {
      "type": "string",
      "minLength": 10
    },
    "queue_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "service_request_count": {
          "type": "integer",
          "minimum": 0
        },
        "status_counts": {
          "type": "object"
        },
        "needs_review_count": {
          "type": "integer",
          "minimum": 0
        },
        "complete_count": {
          "type": "integer",
          "minimum": 0
        },
        "rejected_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "service_request_count",
        "status_counts",
        "needs_review_count",
        "complete_count",
        "rejected_count"
      ]
    },
    "runtime_profiles": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "runtime_id": {
            "type": "string",
            "minLength": 3
          },
          "matrix_decision": {
            "type": "string",
            "minLength": 5
          },
          "safe_now": {
            "type": "boolean"
          },
          "allowed_reducer_mode": {
            "enum": [
              "local_sqlite_dry_run_only",
              "runtime_contract_preview_only"
            ],
            "type": "string"
          },
          "dependency_installs": {
            "const": false
          },
          "dependency_imports": {
            "const": false
          },
          "runtime_starts": {
            "const": 0
          },
          "queue_enqueues": {
            "const": 0
          },
          "api_calls": {
            "const": false
          },
          "external_side_effects": {
            "const": false
          },
          "promotion_gate": {
            "type": "string",
            "minLength": 10
          }
        },
        "required": [
          "runtime_id",
          "matrix_decision",
          "safe_now",
          "allowed_reducer_mode",
          "dependency_installs",
          "dependency_imports",
          "runtime_starts",
          "queue_enqueues",
          "api_calls",
          "external_side_effects",
          "promotion_gate"
        ]
      }
    },
    "service_status_cases": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "status_snapshot": {
            "enum": [
              "needs_review",
              "complete",
              "rejected"
            ],
            "type": "string"
          },
          "event_name": {
            "type": "string",
            "minLength": 10
          },
          "expected_output_state": {
            "type": "string",
            "minLength": 10
          },
          "parked": {
            "type": "boolean"
          },
          "terminal": {
            "type": "boolean"
          },
          "resume_requirements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status_snapshot",
          "event_name",
          "expected_output_state",
          "parked",
          "terminal",
          "resume_requirements"
        ]
      }
    },
    "expected_action_flags": {
      "type": "object"
    },
    "boundary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "next_local_test": {
      "type": "string",
      "minLength": 10
    }
  },
  "required": [
    "schema_version",
    "generated_utc",
    "task_id",
    "lane_id",
    "owner_agent_id",
    "source_matrix_path",
    "source_service_worker_queue_path",
    "source_reducer_result_path",
    "queue_snapshot",
    "runtime_profiles",
    "service_status_cases",
    "expected_action_flags",
    "boundary",
    "next_local_test"
  ]
}
