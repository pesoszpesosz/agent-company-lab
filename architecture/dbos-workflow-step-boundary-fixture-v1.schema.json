{
  "$id": "https://agent-company-lab.local/schemas/dbos-workflow-step-boundary-fixture-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Company DBOS Workflow Step Boundary Fixture v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "agent_company.dbos_workflow_step_boundary_fixture.v1"
    },
    "generated_utc": {
      "type": "string"
    },
    "task_id": {
      "const": "task-dbos-workflow-step-boundary-fixture-v1-20260617"
    },
    "lane_id": {
      "const": "platform_engineering"
    },
    "owner_agent_id": {
      "const": "recovered-profitable-edge-infra"
    },
    "source_urls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "source_service_worker_schema_path": {
      "type": "string",
      "minLength": 10
    },
    "source_service_worker_queue_path": {
      "type": "string",
      "minLength": 10
    },
    "source_inngest_fixture_path": {
      "type": "string",
      "minLength": 10
    },
    "workflow_contract": {
      "type": "object"
    },
    "step_boundary_policy": {
      "type": "object"
    },
    "cases": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 3
          },
          "service_request_id": {
            "type": "string",
            "minLength": 3
          },
          "status_snapshot": {
            "enum": [
              "needs_review",
              "complete",
              "rejected"
            ],
            "type": "string"
          },
          "workflow_id": {
            "type": "string",
            "minLength": 10
          },
          "workflow_options": {
            "type": "object"
          },
          "dbos_runtime_edges": {
            "type": "object"
          },
          "planned_steps": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "expected_state": {
            "type": "string",
            "minLength": 3
          },
          "expected_terminal": {
            "type": "boolean"
          },
          "expected_failures": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "case_id",
          "service_request_id",
          "status_snapshot",
          "workflow_id",
          "workflow_options",
          "dbos_runtime_edges",
          "planned_steps",
          "expected_state",
          "expected_terminal",
          "expected_failures"
        ]
      }
    },
    "runtime_boundary": {
      "type": "object"
    },
    "next_local_test": {
      "type": "string",
      "minLength": 10
    }
  },
  "required": [
    "schema_version",
    "generated_utc",
    "task_id",
    "lane_id",
    "owner_agent_id",
    "source_urls",
    "source_service_worker_schema_path",
    "source_service_worker_queue_path",
    "source_inngest_fixture_path",
    "workflow_contract",
    "step_boundary_policy",
    "cases",
    "runtime_boundary",
    "next_local_test"
  ]
}
