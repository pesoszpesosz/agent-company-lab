{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent_company.browser_worker_adapter_contract.v1",
  "title": "Agent Company Browser Worker Adapter Contract v1",
  "type": "object",
  "required": [
    "adapter_contract_id",
    "request_id",
    "service_id",
    "request_type",
    "lane_id",
    "adapter_kind",
    "runtime_candidate",
    "execution_mode",
    "session_mode",
    "navigation_scope",
    "allowed_domains",
    "target_urls",
    "allowed_action_classes",
    "denied_action_classes",
    "required_artifacts",
    "lifecycle",
    "egress_trace",
    "browser_session_start_allowed",
    "worker_start_allowed",
    "runtime_boundary"
  ],
  "additionalProperties": false,
  "properties": {
    "adapter_contract_id": {
      "type": "string",
      "pattern": "^browser-worker-adapter-contract-[a-z0-9][a-z0-9-]{4,120}$"
    },
    "request_id": {
      "type": "string",
      "minLength": 5
    },
    "service_id": {
      "const": "browser_read_only_session"
    },
    "request_type": {
      "const": "browser_research"
    },
    "lane_id": {
      "type": "string",
      "minLength": 3
    },
    "adapter_kind": {
      "enum": [
        "playwright_deterministic",
        "stagehand_agent_sdk",
        "browser_use_agent",
        "playwright_mcp",
        "agent_browser_cli",
        "cloud_browser_api",
        "browser_extension_agent",
        "agentic_browser_fork"
      ]
    },
    "runtime_candidate": {
      "type": "string",
      "minLength": 3
    },
    "execution_mode": {
      "enum": [
        "report_only_contract",
        "approved_local_dry_run",
        "approved_read_only_browser_session",
        "approved_public_action_session"
      ]
    },
    "session_mode": {
      "enum": [
        "public_read_only_no_login",
        "signed_in_named_scope",
        "private_or_sensitive",
        "unknown"
      ]
    },
    "navigation_scope": {
      "enum": [
        "explicit_allowlist_only",
        "bounded_same_domain",
        "unbounded"
      ]
    },
    "allowed_domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "target_urls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^https://"
      }
    },
    "allowed_action_classes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "denied_action_classes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_artifacts": {
      "type": "object"
    },
    "lifecycle": {
      "type": "object"
    },
    "egress_trace": {
      "type": "object"
    },
    "browser_session_start_allowed": {
      "const": false
    },
    "worker_start_allowed": {
      "const": false
    },
    "runtime_boundary": {
      "type": "object"
    }
  }
}
