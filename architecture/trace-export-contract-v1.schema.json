{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent_company.trace_export_contract.v1",
  "title": "Agent Company Trace Export Contract v1",
  "type": "object",
  "required": [
    "schema_version",
    "generated_utc",
    "source_database",
    "target_backends",
    "redaction_policy",
    "export_spans",
    "external_side_effects"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "agent_company.trace_export_contract.v1"
    },
    "generated_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "source_database": {
      "type": "string",
      "minLength": 3
    },
    "target_backends": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "local_jsonl",
          "opentelemetry_preview",
          "langfuse_preview",
          "phoenix_preview"
        ]
      }
    },
    "redaction_policy": {
      "type": "object",
      "required": [
        "deny_metadata_keys",
        "deny_value_patterns",
        "allowed_export_fields",
        "path_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "deny_metadata_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deny_value_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_export_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "path_policy": {
          "enum": [
            "local_paths_allowed_no_private_file_contents",
            "artifact_ids_only",
            "no_paths"
          ]
        }
      }
    },
    "export_spans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/export_span"
      }
    },
    "external_side_effects": {
      "const": false
    }
  },
  "$defs": {
    "export_span": {
      "type": "object",
      "required": [
        "event_id",
        "trace_id",
        "span_id",
        "parent_span_id",
        "lane_id",
        "task_id",
        "agent_id",
        "event_type",
        "event_time",
        "span_kind",
        "runtime",
        "api_calls",
        "external_side_effects",
        "summary_redacted",
        "artifact_ref",
        "attributes"
      ],
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 3
        },
        "trace_id": {
          "type": "string",
          "minLength": 3
        },
        "span_id": {
          "type": "string",
          "minLength": 3
        },
        "parent_span_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "lane_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "task_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "agent_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "event_type": {
          "type": "string",
          "minLength": 3
        },
        "event_time": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "span_kind": {
          "type": "string",
          "minLength": 3
        },
        "runtime": {
          "type": "string",
          "minLength": 3
        },
        "api_calls": {
          "type": "boolean"
        },
        "external_side_effects": {
          "const": false
        },
        "summary_redacted": {
          "type": "string",
          "minLength": 5,
          "maxLength": 1000
        },
        "artifact_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "attributes": {
          "type": "object"
        }
      }
    }
  }
}
