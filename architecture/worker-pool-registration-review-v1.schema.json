{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent_company.worker_pool_registration_review.v1",
  "title": "Worker Pool Registration Review v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "generated_utc",
    "source_preflight_path",
    "source_registration_plan_path",
    "review_packets",
    "summary",
    "runtime_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "agent_company.worker_pool_registration_review.v1"
    },
    "review_id": {
      "type": "string",
      "pattern": "^worker-pool-registration-review-[a-z0-9-]+$"
    },
    "generated_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source_preflight_path": {
      "type": "string"
    },
    "source_registration_plan_path": {
      "type": "string"
    },
    "review_packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "packet_id",
          "worker_pool_id",
          "worker_type",
          "role_id",
          "department_id",
          "current_request_count",
          "priority",
          "decision_route",
          "manual_command_preview",
          "must_not_do",
          "review_questions"
        ],
        "properties": {
          "packet_id": {
            "type": "string",
            "pattern": "^pool-review-[a-z0-9-]+$"
          },
          "worker_pool_id": {
            "type": "string"
          },
          "worker_type": {
            "type": "string"
          },
          "role_id": {
            "type": "string"
          },
          "department_id": {
            "type": "string"
          },
          "current_request_count": {
            "type": "integer"
          },
          "priority": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "decision_route": {
            "enum": [
              "manual_review_register_later",
              "manual_review_hold",
              "manual_review_reject"
            ]
          },
          "manual_command_preview": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "must_not_do": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "review_questions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_count",
        "high_priority_count",
        "manual_register_later_count",
        "manual_hold_count",
        "commands_executed"
      ],
      "properties": {
        "packet_count": {
          "type": "integer"
        },
        "high_priority_count": {
          "type": "integer"
        },
        "manual_register_later_count": {
          "type": "integer"
        },
        "manual_hold_count": {
          "type": "integer"
        },
        "commands_executed": {
          "const": 0
        }
      }
    },
    "runtime_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_only",
        "registers_pools",
        "assigns_service_requests",
        "starts_workers",
        "updates_service_requests",
        "calls_apis",
        "external_side_effects"
      ],
      "properties": {
        "report_only": {
          "const": true
        },
        "registers_pools": {
          "const": false
        },
        "assigns_service_requests": {
          "const": false
        },
        "starts_workers": {
          "const": false
        },
        "updates_service_requests": {
          "const": false
        },
        "calls_apis": {
          "const": false
        },
        "external_side_effects": {
          "const": false
        }
      }
    }
  }
}
