{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent_company.ceo_dispatch_batch.v1",
  "title": "CEO Dispatch Batch v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "batch_id",
    "generated_utc",
    "source_dag_id",
    "source_contract_path",
    "owner_agent_id",
    "entries",
    "summary",
    "runtime_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "agent_company.ceo_dispatch_batch.v1"
    },
    "batch_id": {
      "type": "string",
      "pattern": "^dispatch-[a-z0-9-]+$"
    },
    "generated_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source_dag_id": {
      "type": "string"
    },
    "source_contract_path": {
      "type": "string"
    },
    "owner_agent_id": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dispatch_id",
          "node_id",
          "lane_id",
          "agent_role",
          "dispatch_status",
          "rank",
          "title",
          "dependency_status",
          "required_gate",
          "recommended_action",
          "expected_artifacts",
          "prohibited_actions"
        ],
        "properties": {
          "dispatch_id": {
            "type": "string",
            "pattern": "^dispatch-node-[a-z0-9-]+$"
          },
          "node_id": {
            "type": "string"
          },
          "lane_id": {
            "type": "string"
          },
          "agent_role": {
            "type": "string"
          },
          "dispatch_status": {
            "enum": [
              "completed_foundation",
              "ready_local_dispatch",
              "blocked_by_gate",
              "waiting_on_dependencies"
            ]
          },
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string"
          },
          "dependency_status": {
            "type": "string"
          },
          "required_gate": {
            "type": "string"
          },
          "recommended_action": {
            "type": "string"
          },
          "expected_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "prohibited_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_count",
        "completed_foundation_count",
        "ready_local_dispatch_count",
        "blocked_by_gate_count",
        "waiting_on_dependencies_count",
        "first_local_dispatch_ids",
        "first_gate_packet_ids"
      ],
      "properties": {
        "entry_count": {
          "type": "integer"
        },
        "completed_foundation_count": {
          "type": "integer"
        },
        "ready_local_dispatch_count": {
          "type": "integer"
        },
        "blocked_by_gate_count": {
          "type": "integer"
        },
        "waiting_on_dependencies_count": {
          "type": "integer"
        },
        "first_local_dispatch_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "first_gate_packet_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runtime_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_only",
        "creates_tasks",
        "approves_actions",
        "starts_workers",
        "updates_service_requests",
        "calls_apis",
        "external_side_effects"
      ],
      "properties": {
        "report_only": {
          "const": true
        },
        "creates_tasks": {
          "const": false
        },
        "approves_actions": {
          "const": false
        },
        "starts_workers": {
          "const": false
        },
        "updates_service_requests": {
          "const": false
        },
        "calls_apis": {
          "const": false
        },
        "external_side_effects": {
          "const": false
        }
      }
    }
  }
}
