{
  "architecture_decisions": [
    {
      "decision_id": "keep_sqlite_as_current_company_brain",
      "next_build": "agent_company_runtime_adoption_docket_v1",
      "rationale": "The highest-fit frameworks converge on durable state, checkpoints, human review, and observability. The local DB already owns lanes, tasks, service requests, artifacts, outcomes, traces, gates, and evidence."
    },
    {
      "decision_id": "treat_frameworks_as_reference_layers_before_dependencies",
      "next_build": "runtime_dependency_install_preflight_v1",
      "rationale": "Most candidates require dependency installs, model/API keys, browser/runtime starts, cloud accounts, telemetry export, or credential flows. Those remain gated while local contracts mature."
    },
    {
      "decision_id": "promote_gateway_and_egress_before_live_tooling",
      "next_build": "unified_agent_egress_gateway_docket_v1",
      "rationale": "MCP/A2A/gateway projects show the right architecture is policy, registry, auth, tracing, and spend controls before live tool calls. The lab already has MCP registry, egress ledger, and adapter contracts."
    },
    {
      "decision_id": "split_agent_workers_by_capability_class",
      "next_build": "worker_capability_class_registry_v1",
      "rationale": "Browser, desktop/computer-use, code worker, model-backed agent, durable workflow, and public-action workers have different risk surfaces. One generic worker pool would be unsafe."
    },
    {
      "decision_id": "observability_becomes_ceo_operating_memory",
      "next_build": "ceo_observability_replay_packet_v1",
      "rationale": "Langfuse, Phoenix, OpenLIT, VoltAgent, and gateway traces point toward replayable traces/evals/costs as executive memory. The local trace/outcome/artifact system is the seed."
    }
  ],
